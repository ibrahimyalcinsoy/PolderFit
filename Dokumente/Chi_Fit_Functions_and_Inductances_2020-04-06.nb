Cell[TextData[{
 "We now switch to the xyz coordinate system shown above. The components that \
need to be used in fitting are the diagonal components of the corresponding \
susceptibilities (we have to be careful with choosing the correct component \
for the IP susceptibility). ",
 StyleBox["We always divide \[Chi] by Ms for the fits (in Labview, FTF) only. \
All other occurences of \[Chi] in equations are unitless.",
  FontWeight->"Bold"],
 " For the case of H along z, only the driving field along y can couple:"
}], "Text",
 CellChangeTimes->{{3.794843315331624*^9, 3.794843360130339*^9}, {
  3.7948436054296255`*^9, 3.7948436180151014`*^9}, {3.7951938511221485`*^9, 
  3.795193867623355*^9}, {3.7951938984037237`*^9, 
  3.79519390208351*^9}},ExpressionUUID->"f989d2ff-6088-4592-92f2-\
315a2ea61413"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Chi]fitZ", "=", 
  FractionBox[
   RowBox[{"\[Chi]OOP", "[", 
    RowBox[{"[", 
     RowBox[{"2", ",", "2"}], "]"}], "]"}], "Ms"]}]], "Input",
 CellChangeTimes->{{3.7831488705059743`*^9, 3.78314891012847*^9}, {
  3.7831496021691113`*^9, 3.783149607956985*^9}, {3.7948431557517815`*^9, 
  3.7948431568457975`*^9}, {3.7948432011568103`*^9, 3.794843218783908*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"9e68c430-a854-4ae1-b253-b5587f4df3ed"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[Gamma]", " ", "\[Mu]0", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[Gamma]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}]}], "+", 
     RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Omega]"}]}], ")"}]}], 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[Gamma]", "2"], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}], "2"]}], "+", 
   RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Gamma]", " ", 
    RowBox[{"(", 
     RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}], " ", "\[Omega]"}], "-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["\[Alpha]", "2"]}], ")"}], " ", 
    SuperscriptBox["\[Omega]", "2"]}]}]]], "Output",
 CellChangeTimes->{
  3.783149621959456*^9, 3.783874400638857*^9, 3.794843172221106*^9, {
