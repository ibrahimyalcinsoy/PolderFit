          RowBox[{"\[Chi]", ".", "h1"}], ")"}], "[", 
         RowBox[{"[", "3", "]"}], "]"}]}]}], "}"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Chi]xy", "\[Rule]", " ", "0"}], ",", " ", 
       RowBox[{"\[Chi]yy", "\[Rule]", "0"}], ",", " ", 
       RowBox[{"\[Chi]zy", "\[Rule]", "0"}], ",", " ", 
       RowBox[{"\[Chi]yx", "\[Rule]", "0"}], ",", " ", 
       RowBox[{"\[Chi]yz", "\[Rule]", "0"}]}], "}"}]}]}], ";"}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.783074772173849*^9, 3.7830747872385964`*^9}, 
   3.7830748242267323`*^9, {3.7830749474142475`*^9, 3.783074949164933*^9}, {
   3.7830750476359205`*^9, 3.7830750857524524`*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"92fb3396-616e-4b4d-81c6-4424636d1ceb"],

Cell["\<\
We can now calculate the currents from Eq 14 (Berger). First, we consider H \
applied along z and the appropriate symmetry of \[Chi] components\
\>", "Text",
 CellChangeTimes->{{3.7818695321719956`*^9, 3.78186954001478*^9}, {
  3.781870461049178*^9, 3.781870476515566*^9}, {3.781870624176054*^9, 
  3.7818706246090975`*^9}, {3.7819395611830363`*^9, 3.7819395654960365`*^9}, {
  3.7819579142899065`*^9, 3.781957916453123*^9}, {3.783075176811694*^9, 
  3.7830751856601377`*^9}, {3.7830753277493424`*^9, 
  3.7830753419361563`*^9}},ExpressionUUID->"432b08e4-bcaf-4227-b86e-\
20c755dc93aa"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LNMZ", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"-", "L12"}], "I0"], " ", 
     RowBox[{"x0", ".", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"z0", " ", "\[Cross]", " ", "dtmZ"}], " ", "\[Sigma]FL"}], 
        "-", 
        RowBox[{
         RowBox[{"z0", " ", "\[Cross]", 
          RowBox[{"(", " ", 
           RowBox[{"mZ", "\[Cross]", " ", "dtmZ"}], ")"}]}], " ", 
         "\[Sigma]DL"}]}], ")"}]}], 
     FractionBox[
      RowBox[{"\[HBar]", " ", "w"}], 
      RowBox[{"2", " ", "e"}]]}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Chi]xy", "\[Rule]", 
       RowBox[{"\[ImaginaryI]", " ", "\[Chi]yy"}]}], ",", " ", 
      RowBox[{"hy", "\[Rule]", 
       RowBox[{"\[Xi]", " ", 
        RowBox[{"I0", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "w"}], ")"}]}], "\[Eta]0"}]}]}], "}"}]}], "//", 
   "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.7818726588039055`*^9, 3.7818726607820635`*^9}, {
   3.781873487247328*^9, 3.7818735055538335`*^9}, {3.7830751934714985`*^9, 
   3.7830752045603223`*^9}, {3.7830752558061867`*^9, 
   3.7830752584570065`*^9}, {3.7830752927546835`*^9, 3.7830753047117453`*^9}, 
   3.783075353557655*^9, {3.783075436138686*^9, 3.7830754385698757`*^9}, {
   3.7830755520143833`*^9, 3.7830755767885365`*^9}, {3.7948472741316853`*^9, 
   3.794847274701868*^9}},
 CellLabel->"In[56]:=",ExpressionUUID->"5882eb38-d473-44f7-a016-c64978ef8e2d"],

Cell[BoxData[
 FractionBox[
  RowBox[{"L12", " ", "\[Eta]0", " ", "\[Xi]", " ", 
   RowBox[{"(", 
    RowBox[{"\[Sigma]DL", "+", 
     RowBox[{"\[ImaginaryI]", " ", "\[Sigma]FL"}]}], ")"}], " ", "\[Chi]yy", 
   " ", "\[Omega]", " ", "\[HBar]"}], 
  RowBox[{"4", " ", "e", " ", "Ms"}]]], "Output",
 CellChangeTimes->{
  3.7818735224022803`*^9, 3.781939789731586*^9, 3.7819552363997984`*^9, 
   3.7830752054502525`*^9, 3.783075263413954*^9, 3.783075355173356*^9, {
   3.783075543524227*^9, 3.783075577674185*^9}, 3.783147709841793*^9, 
   3.7838744404105225`*^9, 3.794847230827219*^9, 3.794847276272138*^9, 
   3.7948487490868087`*^9, 3.794901326719742*^9, 3.795193168040007*^9},
 CellLabel->"Out[56]=",ExpressionUUID->"c1cbdaa2-bc9f-401a-bcb3-e2db359f95c6"]
}, Open  ]],

Cell[TextData[{
 "For H along x we use ",
 Cell[BoxData[
  RowBox[{"\[Chi]IP", "=", 
   RowBox[{"\[Chi]zyIP", 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{"\[ImaginaryI]", " ", "\[Epsilon]"}], 
        RowBox[{"-", "1"}]},
       {"1", 
        FractionBox["\[ImaginaryI]", "\[Epsilon]"]}
      }], "\[NoBreak]", ")"}]}]}]],
  CellChangeTimes->{{3.781939880245586*^9, 3.7819399491015863`*^9}},
  ExpressionUUID->"6f5db360-970b-4317-b25c-b54fcdb2b68e"],
 ". Importantly we have to consider that any response (m or J) due to the z \
driving field will be antisymmetric if mirrored along the xz-plane. Thus, \
currents due to the z driving field do not contribute to the inductance. "
}], "Text",
 CellChangeTimes->{{3.783075762898162*^9, 3.7830757715616183`*^9}, {
   3.7830759354449434`*^9, 3.783075944546606*^9}, {3.7830759961824102`*^9, 
   3.783076001211954*^9}, {3.783076708129117*^9, 3.783076720231005*^9}, {
   3.7830776572615623`*^9, 3.7830777643458986`*^9}, 3.783077968227683*^9, {
   3.794847921938326*^9, 
   3.7948479248398366`*^9}},ExpressionUUID->"c4d34a86-643a-48ba-ad98-\
b4f3028c144c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LNMX", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"-", "L12"}], "I0"], " ", 
     RowBox[{"x0", ".", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"z0", " ", "\[Cross]", " ", "dtmX"}], " ", "\[Sigma]FL"}], 
        "-", 
        RowBox[{
         RowBox[{"z0", " ", "\[Cross]", 
          RowBox[{"(", " ", 
           RowBox[{"mX", "\[Cross]", " ", "dtmX"}], ")"}]}], " ", 
         "\[Sigma]DL"}]}], ")"}]}], 
     FractionBox[
      RowBox[{"\[HBar]", " ", "w"}], 
      RowBox[{"2", " ", "e"}]]}], "/.", 
    RowBox[{"{", " ", 
     RowBox[{
      RowBox[{"hy", "\[Rule]", 
       RowBox[{"\[Xi]", " ", 
        RowBox[{"I0", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "w"}], ")"}]}], "\[Eta]0"}]}], ",", " ", 
      RowBox[{"hz", "\[Rule]", " ", "0"}], ",", " ", 
      RowBox[{"\[Chi]yz", "\[Rule]", 
       RowBox[{"-", "\[Chi]zy"}]}], ",", " ", 
      RowBox[{"\[Chi]yy", "\[Rule]", 
       RowBox[{"(", 
        RowBox[{"\[ImaginaryI]", " ", "\[Epsilon]", " ", "\[Chi]zy"}], 
        ")"}]}], ",", " ", 
      RowBox[{"\[Chi]zz", "\[Rule]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[ImaginaryI]", " ", "/", "\[Epsilon]"}], " ", "\[Chi]zy"}],
         ")"}]}]}], "  ", "}"}]}], "//", "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.7830757813574305`*^9, 3.7830758341509423`*^9}, {
   3.783075971638378*^9, 3.7830759721070023`*^9}, {3.783076014892685*^9, 
   3.7830760164822783`*^9}, {3.783076145476034*^9, 3.783076151238465*^9}, {
   3.78307621028943*^9, 3.783076216030835*^9}, {3.783076259227214*^9, 
   3.783076264542857*^9}, {3.7830763171312256`*^9, 3.783076340496082*^9}, {
   3.7830763793981605`*^9, 3.7830764118873415`*^9}, {3.7830764669105234`*^9, 
   3.783076475799204*^9}, {3.7830765403342714`*^9, 3.7830765408431797`*^9}, 
   3.7830766538498764`*^9, {3.794847290474115*^9, 3.7948472909323006`*^9}},
 CellLabel->"In[57]:=",ExpressionUUID->"09855fca-cab5-4a03-9ab3-7a7a78da49fb"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[ImaginaryI]", " ", "L12", " ", "\[Eta]0", " ", "\[Xi]", " ", 
   RowBox[{"(", 
    RowBox[{"\[Sigma]DL", "+", 
     RowBox[{"\[ImaginaryI]", " ", "\[Epsilon]", " ", "\[Sigma]FL"}]}], ")"}],
    " ", "\[Chi]zy", " ", "\[Omega]", " ", "\[HBar]"}], 
