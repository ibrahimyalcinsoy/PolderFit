Cell[CellGroupData[{

Cell["Fitting equations for Labview", "Chapter",
 CellChangeTimes->{{3.7948442916598277`*^9, 3.794844318920144*^9}, {
  3.794844417952197*^9, 
  3.7948444216292753`*^9}},ExpressionUUID->"15579801-5d45-49b5-b2b2-\
e6b95f0df6c6"],

Cell["\<\
In the following, we give the fit equations that should be copy + pasted into \
Labview\
\>", "Text",
 CellChangeTimes->{{3.7948487609947853`*^9, 
  3.794848794927947*^9}},ExpressionUUID->"7d6c2eb0-9402-4552-95fa-\
f77cc3e04961"],

Cell[BoxData[
 RowBox[{
  RowBox[{"replacementrules", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Gamma]", "\[Rule]", "gamma"}], ",", " ", 
     RowBox[{"\[Mu]0", "\[Rule]", "mu0"}], ",", " ", 
     RowBox[{"\[Alpha]", "\[Rule]", "alpha"}], ",", " ", 
     RowBox[{"\[Mu]0H0", "\[Rule]", "mu0H0"}], ",", " ", 
     RowBox[{"\[Omega]", "\[Rule]", "omega"}], ",", " ", 
     RowBox[{"\[Mu]0Meff", "\[Rule]", "mu0Meff"}], ",", " ", 
     RowBox[{"\[Zeta]", "\[Rule]", "ratio"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7948439212478437`*^9, 3.7948439736874404`*^9}, {
   3.7948446473106976`*^9, 3.7948446494567895`*^9}, 3.794845757900598*^9},
 CellLabel->"In[11]:=",ExpressionUUID->"0a672f0b-9e5e-4b71-a9c6-2dd3c6e7dee3"],

Cell[CellGroupData[{

Cell["Out-of-plane (H || z):", "Section",
 CellChangeTimes->{{3.7948443295345974`*^9, 3.794844339661627*^9}, {
  3.7948445496592045`*^9, 3.7948445729392567`*^9}, {3.7948456016441107`*^9, 
  3.794845618419636*^9}},ExpressionUUID->"32ff485f-7281-441a-8c48-\
775b45f36f66"],

Cell["OOP real:", "Text",
 CellChangeTimes->{{3.794844357524457*^9, 
  3.7948443755546017`*^9}},ExpressionUUID->"716cacd2-f8e1-483c-b36f-\
6998ef54992a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ToString", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Re", "[", "\[Chi]fitZ", "]"}], "]"}], "/.", 
     "replacementrules"}], "//", "FullSimplify"}], "//", "FortranForm"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.794843656808736*^9, 3.794843666694934*^9}, {
  3.794843717892541*^9, 3.7948437736020007`*^9}, {3.7948438585413713`*^9, 
  3.794843890055651*^9}, {3.7948439814060187`*^9, 3.794844008638214*^9}},
 CellLabel->"In[12]:=",ExpressionUUID->"9438e489-b595-43df-bb53-56ec5e1728a7"],

Cell[BoxData["\<\"(gamma**2*mu0*(mu0H0 - mu0Meff)*(gamma**2*(mu0H0 - \
mu0Meff)**2 + (-1 + alpha**2)*omega**2))/(gamma**4*(mu0H0 - mu0Meff)**4 + \
2*(-1 + alpha**2)*gamma**2*(mu0H0 - mu0Meff)**2*omega**2 + (1 + \
alpha**2)**2*omega**4)\"\>"], "Output",
 CellChangeTimes->{{3.7948437279998274`*^9, 3.7948437741187143`*^9}, {
   3.794843860972645*^9, 3.7948438906176786`*^9}, 3.794843992581482*^9, 
   3.794848725226217*^9, 3.794901289680089*^9, 3.795193129866333*^9},
 CellLabel->"Out[12]=",ExpressionUUID->"644b67e5-7792-4839-ac39-3dea830644c0"]
}, Open  ]],

Cell["OOP imaginary :", "Text",
 CellChangeTimes->{{3.7948443702644405`*^9, 
  3.794844398065406*^9}},ExpressionUUID->"934befdf-5b70-4a04-82b3-\
dc6b9a8f5b6d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ToString", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Im", "[", "\[Chi]fitZ", "]"}], "]"}], "/.", 
     "replacementrules"}], "//", "FullSimplify"}], "//", "FortranForm"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.794843656808736*^9, 3.794843666694934*^9}, {
  3.794843717892541*^9, 3.7948437736020007`*^9}, {3.7948438585413713`*^9, 
  3.794843890055651*^9}, {3.7948439814060187`*^9, 3.794844008638214*^9}, {
  3.794844384113356*^9, 3.794844384406371*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"708724a6-121d-4b2a-94cb-76d6f14fb3b4"],

Cell[BoxData["\<\"-((alpha*gamma*mu0*omega*(gamma**2*(mu0H0 - mu0Meff)**2 + \
(1 + alpha**2)*omega**2))/(gamma**4*(mu0H0 - mu0Meff)**4 + 2*(-1 + \
alpha**2)*gamma**2*(mu0H0 - mu0Meff)**2*omega**2 + (1 + \
alpha**2)**2*omega**4))\"\>"], "Output",
 CellChangeTimes->{{3.7948437279998274`*^9, 3.7948437741187143`*^9}, {
   3.794843860972645*^9, 3.7948438906176786`*^9}, 3.794843992581482*^9, 
   3.7948443850012503`*^9, 3.7948487252562175`*^9, 3.7949012897250795`*^9, 
   3.7951931299153214`*^9},
 CellLabel->"Out[13]=",ExpressionUUID->"c261d2b1-05c1-439e-aec5-be420cf114c3"]
}, Open  ]]
}, Open  ]],

