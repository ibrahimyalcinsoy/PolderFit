Cell["\<\
Evidently, AyEval=AzEval/4 for all values of z and in the limit of z -> 0 we \
find:\
\>", "Text",
 CellChangeTimes->{{3.782578951969652*^9, 3.782578997850884*^9}, {
   3.7825791053279552`*^9, 3.7825791097157354`*^9}, 3.782579387962*^9, {
   3.78257948104688*^9, 3.782579486732455*^9}, {3.7825795201265078`*^9, 
   3.7825795375680776`*^9}},ExpressionUUID->"4725980d-b10a-4895-8a84-\
ae982a979b8d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"A0z", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"Log", "[", 
       FractionBox[
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"w", "/", "2"}], "+", "y"}], ")"}], "2"], 
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{
           RowBox[{"w", "/", "2"}], "-", "y"}], ")"}], "2"]], "]"}], ")"}], 
     "2"], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
      RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}], ",", " ", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{"w", ">", "0"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7825790585662947`*^9, 3.782579075821739*^9}, {
   3.782579149810443*^9, 3.78257915253317*^9}, {3.782579248291222*^9, 
   3.7825792533229933`*^9}, {3.782579437479395*^9, 3.782579437799535*^9}, 
   3.7825794919953346`*^9},
 CellLabel->"In[38]:=",ExpressionUUID->"7cdf7168-8e42-42a0-ad21-503185119c3d"],

Cell[BoxData[
 RowBox[{"4", " ", 
  SuperscriptBox["\[Pi]", "2"], " ", "w"}]], "Output",
 CellChangeTimes->{3.7825792133469095`*^9, 3.782579267119845*^9, 
  3.782579447094411*^9, 3.7825795777303505`*^9, 3.7827945472233915`*^9, 
  3.7830743744778357`*^9, 3.7831476749284487`*^9, 3.783874412846339*^9, 
  3.794846053782181*^9, 3.794848732208457*^9, 3.7949013034429708`*^9, 
  3.7951931445858684`*^9},
 CellLabel->"Out[38]=",ExpressionUUID->"aa03412e-e091-4d56-ae7f-a983b425e9dc"]
}, Open  ]],

