      RowBox[{"z", ",", "1"}], "]"}], ",", 
     RowBox[{"AzEval", "[", 
      RowBox[{"z", ",", "1"}], "]"}], ",", " ", 
     RowBox[{
      RowBox[{"AzEval", "[", 
       RowBox[{"z", ",", "1"}], "]"}], "/", "4"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", "0", ",", "1"}], "}"}], ",", " ", 
   RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]], "Input",
