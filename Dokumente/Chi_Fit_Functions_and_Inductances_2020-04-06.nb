        RowBox[{"[", "3", "]"}], "]"}]}]}], "}"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Chi]xx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]yx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]xy", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]xz", "\[Rule]", "0"}]}], "}"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.781870738626547*^9, 3.7818707801370754`*^9}, 
