d0445dd903cb"],

Cell[CellGroupData[{

Cell["H || z", "Section",
 CellChangeTimes->{{3.794849391514888*^9, 3.794849398604686*^9}, {
  3.7948499088285007`*^9, 
  3.794849911396118*^9}},ExpressionUUID->"7a8dd958-b3fb-4176-b88d-\
724b8fe5917f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Lz", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"d", " ", "l", " ", "\[Mu]0", " "}], 
      RowBox[{"4", " ", "w"}]], 
     SuperscriptBox["\[Xi]", "2"], "\[Chi]Z", " ", 
     SuperscriptBox["\[Eta]0", "2"]}], "+", 
    RowBox[{"\[ImaginaryI]", " ", "L12", " ", 
     FractionBox[
      RowBox[{
       RowBox[{"(", 
        RowBox[{"\[Sigma]DL", "+", 
         RowBox[{"\[ImaginaryI]", " ", "\[Sigma]FL"}]}], ")"}], "  ", 
       "\[HBar]", " ", "\[Omega]", " "}], 
      RowBox[{"2", " ", "e", " ", "Ms"}]], " ", "\[Xi]", " ", "\[Eta]0", " ", 
     "\[Chi]Z"}]}]}], " ", ";"}]], "Input",
 CellChangeTimes->{{3.7948491078985996`*^9, 3.7948492383905315`*^9}, 
   3.7948493507756743`*^9},
 CellLabel->"In[61]:=",ExpressionUUID->"7fbcbc50-0245-4ec2-9e71-1336a85c19a3"],

Cell["With real part", "Text",
 CellChangeTimes->{{3.794849401053666*^9, 
  3.7948494035608196`*^9}},ExpressionUUID->"d543dcfc-b911-458b-b6a2-\
52e6d85fe5e0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ReLz", "=", 
  RowBox[{"Collect", "[", 
   RowBox[{
    RowBox[{"Simplify", "[", 
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Re", "[", "Lz", "]"}], "]"}], "]"}], ",", "\[Eta]0"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.7948493549029417`*^9, 3.794849369096525*^9}, {
  3.794849740743162*^9, 3.7948497814184513`*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"2cba3c9d-1adf-4fd3-b003-5f8e3bb9b30d"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   RowBox[{"d", " ", "l", " ", 
    SuperscriptBox["\[Eta]0", "2"], " ", "\[Mu]0", " ", 
    SuperscriptBox["\[Xi]", "2"], " ", "\[Chi]Z"}], 
   RowBox[{"4", " ", "w"}]], "-", 
  FractionBox[
   RowBox[{
   "L12", " ", "\[Eta]0", " ", "\[Xi]", " ", "\[Sigma]FL", " ", "\[Chi]Z", 
    " ", "\[Omega]", " ", "\[HBar]"}], 
   RowBox[{"2", " ", "e", " ", "Ms"}]]}]], "Output",
 CellChangeTimes->{
  3.794849369633524*^9, {3.7948497461058207`*^9, 3.79484978196847*^9}, 
   3.794901327012764*^9, 3.79519316849059*^9},
 CellLabel->"Out[62]=",ExpressionUUID->"7c1fd606-1476-473b-81db-bf76af2c3552"]
}, Open  ]],

Cell["And imaginary part", "Text",
 CellChangeTimes->{{3.7948494069428186`*^9, 3.7948494091383915`*^9}, 
