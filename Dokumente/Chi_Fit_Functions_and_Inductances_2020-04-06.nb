      "\[Sigma]DL"}], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}], " ", "\[Sigma]FL"}]}], 
