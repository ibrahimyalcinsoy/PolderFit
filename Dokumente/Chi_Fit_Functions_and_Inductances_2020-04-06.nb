Cell[BoxData[
 RowBox[{"\[Chi]fitX", "=", 
  FractionBox[
   RowBox[{"\[Gamma]", " ", "\[Mu]0", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"(", 
        RowBox[{"\[Mu]0H0", "+", 
         RowBox[{"\[Zeta]", " ", "\[Mu]0H0"}], "+", "\[Mu]0Meff"}], ")"}]}], 
      "+", 
      RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", "\[Zeta]"}], ")"}], " ", "\[Omega]"}]}], ")"}]}], 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Gamma]", "2"], " ", "\[Mu]0H0", " ", 
     RowBox[{"(", 
      RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}], "+", 
    RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Gamma]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "\[Mu]0H0"}], "+", "\[Mu]0Meff"}], ")"}], " ", 
     "\[Omega]"}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       SuperscriptBox["\[Alpha]", "2"]}], ")"}], " ", 
     SuperscriptBox["\[Omega]", "2"]}]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.783873740713147*^9, 3.7838737423283787`*^9}, 
   3.79484662929352*^9},ExpressionUUID->"f90ed11c-ae24-4c05-b650-\
17a27a44f187"],

Cell[BoxData[
 RowBox[{"\[Chi]fitY", "=", 
  FractionBox[
   RowBox[{"\[Gamma]", " ", "\[Mu]0", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Gamma]", " ", "\[Mu]0H0"}], "+", 
      RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Omega]"}]}], ")"}]}], 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Gamma]", "2"], " ", "\[Mu]0H0", " ", 
     RowBox[{"(", 
      RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}], "+", 
    RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Gamma]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "\[Mu]0H0"}], "+", "\[Mu]0Meff"}], ")"}], " ", 
     "\[Omega]"}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       SuperscriptBox["\[Alpha]", "2"]}], ")"}], " ", 
     SuperscriptBox["\[Omega]", "2"]}]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.7838738660774803`*^9, 3.783873868705496*^9}, 
   3.7948466421887856`*^9},ExpressionUUID->"d95fa372-95c8-43f1-9e8a-\
c83e2f5500cf"],

Cell[BoxData[
 RowBox[{"\[Chi]fitZ", "=", 
  FractionBox[
   RowBox[{"\[Gamma]", " ", "\[Mu]0", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"\[Gamma]", " ", 
       RowBox[{"(", 
        RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}]}], "+", 
      RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Omega]"}]}], ")"}]}], 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[Gamma]", "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}], "2"]}], "+", 
    RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Gamma]", " ", 
     RowBox[{"(", 
      RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}], " ", "\[Omega]"}], "-", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "+", 
       SuperscriptBox["\[Alpha]", "2"]}], ")"}], " ", 
     SuperscriptBox["\[Omega]", "2"]}]}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.7831508457490063`*^9, 3.7831508495891647`*^9}, {
  3.7948466539426637`*^9, 
  3.794846666202413*^9}},ExpressionUUID->"693d7e58-96a2-44f6-b772-\
4922fedc4745"]
}, Open  ]]
