   "FullSimplify"}], "//", "MatrixForm"}]], "Input",
 CellChangeTimes->{{3.7948434356711483`*^9, 3.7948434848150396`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"166f0d40-268b-4401-a840-c90394c75602"],

Cell[BoxData[
 TagBox[
  RowBox[{"(", "\[NoBreak]", GridBox[{
     {
      FractionBox[
       RowBox[{
        RowBox[{"\[Gamma]", " ", "\[Mu]0H0"}], "-", 
        RowBox[{"\[Gamma]", " ", "\[Mu]0Meff"}], "+", 
