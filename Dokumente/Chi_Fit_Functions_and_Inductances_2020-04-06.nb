Cell[CellGroupData[{

Cell["Susceptibilities", "Chapter",
 CellChangeTimes->{{3.7948445030929685`*^9, 
  3.794844512481234*^9}},ExpressionUUID->"957d08c4-d92e-425b-8282-\
260c88544415"],

Cell["\<\
Fitting the raw S21 data has to consider the corresponding susceptibility \
tensor components (taken from Habil MW Equation 2.7). For these equations the \
3 direction is along the M equilibrium orientation and \[Chi] describes the \
orthogonal 1 and 2 components with the 2 direction always in-plane.\
\>", "Text",
 CellChangeTimes->{{3.783148471682973*^9, 3.7831485111999407`*^9}, {
   3.7948428949620595`*^9, 3.7948430076933846`*^9}, 
   3.7948445012926683`*^9},ExpressionUUID->"1bcc63a9-5f61-4a47-85c5-\
d814dd5a6bbc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Chi]invoop", "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Mu]0", " ", "\[Gamma]"}]], 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{
         RowBox[{"\[Gamma]", 
          RowBox[{"(", 
           RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}]}], "+", 
         RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Omega]"}]}], 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]"}]},
       {
        RowBox[{"\[ImaginaryI]", " ", "\[Omega]"}], 
        RowBox[{
         RowBox[{"\[Gamma]", 
          RowBox[{"(", 
           RowBox[{"\[Mu]0H0", "-", "\[Mu]0Meff"}], ")"}]}], "+", 
         RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Omega]"}]}]}
      }], "\[NoBreak]", ")"}]}]}], ";"}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"8d19183d-4aa0-464d-ba11-e5486a0c13d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Chi]invip", "=", 
   RowBox[{
    FractionBox["1", 
     RowBox[{"\[Mu]0", " ", "\[Gamma]"}]], 
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {
        RowBox[{
         RowBox[{"\[Gamma]", " ", 
          RowBox[{"(", 
           RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}], "+", 
         RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Omega]"}]}], 
        RowBox[{
         RowBox[{"-", "\[ImaginaryI]"}], " ", "\[Omega]"}]},
       {
        RowBox[{"\[ImaginaryI]", " ", "\[Omega]"}], 
        RowBox[{
         RowBox[{"\[Gamma]", " ", "\[Mu]0H0"}], "+", 
         RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Omega]"}]}]}
      }], "\[NoBreak]", ")"}]}]}], ";"}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"7e1f3edd-9a47-4f6e-9747-606cc3232421"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Chi]OOP", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Inverse", "[", "\[Chi]invoop", "]"}], "*", "Ms"}], "//", 
    "FullSimplify"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.783148726612688*^9, 3.7831487637374473`*^9}, 
   3.7831488476755524`*^9, {3.783148916633281*^9, 3.783148932997883*^9}, {
