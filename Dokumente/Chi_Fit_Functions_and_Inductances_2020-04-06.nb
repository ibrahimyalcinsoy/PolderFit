Cell["\<\
For H along x, both IP and OOP driving fields can couple. Here \[Xi] is the \
ratio between the coupling efficiency. \[Zeta]=1 is expected for an \
insulating ferromagnet, however in the presence of microwave shielding the IP \
and OOP driving fields may be shielded with different efficiency, resulting \
in \[Zeta] \[NotEqual]1.\
\>", "Text",
 CellChangeTimes->{{3.7948433810193715`*^9, 3.7948433922972784`*^9}, {
  3.7948441563209*^9, 3.7948442506965857`*^9}, {3.7948457507873507`*^9, 
  3.7948457532452755`*^9}},ExpressionUUID->"9c4515cd-ff2e-44c3-91c3-\
f6cf19961278"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Chi]fitX", "=", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"\[Zeta]", " ", 
      RowBox[{"\[Chi]IP", "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], "+", " ", 
     RowBox[{"\[Chi]IP", "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "2"}], "]"}], "]"}]}], "Ms"], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.7831489905473676`*^9, 3.783149019077039*^9}, {
  3.79484413301724*^9, 3.7948441450597954`*^9}, {3.794844269496873*^9, 
  3.7948442856340513`*^9}, {3.7948457299415703`*^9, 3.7948457436243553`*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"05197dbd-43a8-48c3-bf2f-b690263c318c"],

Cell[BoxData[
 FractionBox[
  RowBox[{"\[Gamma]", " ", "\[Mu]0", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[Gamma]", " ", 
      RowBox[{"(", 
       RowBox[{"\[Mu]0H0", "+", 
        RowBox[{"\[Zeta]", " ", "\[Mu]0H0"}], "+", "\[Mu]0Meff"}], ")"}]}], 
     "+", 
     RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", "\[Zeta]"}], ")"}], " ", "\[Omega]"}]}], ")"}]}], 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[Gamma]", "2"], " ", "\[Mu]0H0", " ", 
    RowBox[{"(", 
     RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}], "+", 
   RowBox[{"\[ImaginaryI]", " ", "\[Alpha]", " ", "\[Gamma]", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", "\[Mu]0H0"}], "+", "\[Mu]0Meff"}], ")"}], " ", 
    "\[Omega]"}], "-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      SuperscriptBox["\[Alpha]", "2"]}], ")"}], " ", 
    SuperscriptBox["\[Omega]", "2"]}]}]]], "Output",
 CellChangeTimes->{{3.7831490155019584`*^9, 3.783149019757518*^9}, 
   3.7831493877212114`*^9, 3.7838744007336025`*^9, 3.7948435810352516`*^9, 
   3.7948441500172873`*^9, 3.7948442861890354`*^9, 3.794846482871279*^9, 
   3.7948487251632175`*^9, 3.794901289537092*^9, 3.7951931296735463`*^9},
 CellLabel->"Out[10]=",ExpressionUUID->"e1d70f03-79ba-4ba9-a112-a980873e6cdf"]
