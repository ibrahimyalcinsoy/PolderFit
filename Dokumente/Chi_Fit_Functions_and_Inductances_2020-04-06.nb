 FractionBox[
  RowBox[{"\[Eta]0", " ", "\[Xi]", " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
     "d", " ", "e", " ", "l", " ", "Ms", " ", "\[Eta]0", " ", "\[Mu]0", " ", 
      "\[Xi]"}], "-", 
     RowBox[{
     "L12", " ", "w", " ", "\[Sigma]FL", " ", "\[Omega]", " ", "\[HBar]"}]}], 
    ")"}]}], 
  RowBox[{"4", " ", "e", " ", "Ms", " ", "w"}]]], "Output",
