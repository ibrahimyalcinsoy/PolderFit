Cell["\<\
We next try to find an analytical equation that approximates the spacing loss \
better than the simple \[Eta] used so far:\
\>", "Text",
 CellChangeTimes->{{3.783148358491232*^9, 
  3.7831483881871386`*^9}},ExpressionUUID->"dc7c0902-5a95-4667-871f-\
65d3be80e8c7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Eta]exactlist", "=", 
   RowBox[{"Join", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], "}"}], ",", 
     RowBox[{"ParallelTable", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"z", ",", 
         RowBox[{
          SqrtBox[
           RowBox[{
            RowBox[{"AyEval", "[", 
             RowBox[{"z", ",", "1"}], "]"}], "/", "A0y"}]], "/.", 
          RowBox[{"{", 
           RowBox[{"w", "\[Rule]", "1"}], "}"}]}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"z", ",", "0.01", ",", "10", ",", "0.01"}], "}"}]}], "]"}]}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.782794691141074*^9, 3.78279470984164*^9}, {
  3.7827948237271414`*^9, 3.7827948320313983`*^9}, {3.7827948977854004`*^9, 
