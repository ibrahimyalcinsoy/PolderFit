 RowBox[{
  RowBox[{"\[Epsilon]0", "=", 
   SqrtBox[
    RowBox[{"1", "+", 
     FractionBox["\[Mu]0Meff", "\[Mu]0H0"]}]]}], ";"}]], "Input",
 CellLabel->"In[58]:=",ExpressionUUID->"befefae7-8feb-4cf7-87b6-96b1ab3b9ca8"],

