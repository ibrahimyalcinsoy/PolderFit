  3.7825798394718027`*^9}},ExpressionUUID->"255cf2be-eb92-4ca3-a770-\
79830a3b3942"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"L0y", "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["Ayint", "2"], "\[Rule]", "A0y"}], ",", " ", 
     RowBox[{
      SuperscriptBox["Azint", "2"], "\[Rule]", "A0z"}]}], "}"}]}], "//", 
  "FullSimplify"}]], "Input",
