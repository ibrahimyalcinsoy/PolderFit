Cell[BoxData[
 RowBox[{"LNMY", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"-", "L12"}], "I0"], " ", 
     RowBox[{"x0", ".", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"z0", " ", "\[Cross]", " ", "dtmY"}], " ", "\[Sigma]FL"}], 
