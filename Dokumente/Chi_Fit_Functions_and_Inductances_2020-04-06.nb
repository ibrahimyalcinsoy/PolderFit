  3.7949017402319984`*^9}},ExpressionUUID->"43c55b26-cbf5-4019-bf3f-\
a3833b84d29b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"Im", "[", "Lx0", "]"}], "]"}], ",", " ", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"\[Mu]0H0", ">", "0"}], "&&", 
     RowBox[{"\[Mu]0Meff", ">", "0"}], "&&", 
