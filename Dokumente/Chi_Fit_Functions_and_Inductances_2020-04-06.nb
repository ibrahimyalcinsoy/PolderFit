Cell[CellGroupData[{

Cell["Final equations for dipolar inductance", "Section",
 CellChangeTimes->{{3.7948469992110167`*^9, 3.7948470021270137`*^9}, {
  3.7948471141722984`*^9, 
  3.7948471195729885`*^9}},ExpressionUUID->"1d615511-37ee-4e7c-a8df-\
7156aeb7af38"],

Cell["\<\
The simplification when using eta is reasonably good for our purposes, but \
exact \[Eta] (\[Eta]new) can also easily be used if necessary. The final \
equations to use for the dipolar inductance are thus\
\>", "Text",
 CellChangeTimes->{{3.782793931785084*^9, 3.7827940541660814`*^9}, {
  3.782794323611573*^9, 3.782794331582818*^9}, {3.7827946635031986`*^9, 
  3.782794681161765*^9}, {3.7831484454520626`*^9, 
  3.7831484487936993`*^9}},ExpressionUUID->"0011e3bb-7ad9-4b2c-a380-\
d7beed7e26ae"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{"L0z", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       SuperscriptBox["Ayint", "2"], "\[Rule]", "A0y"}], ",", " ", 
      RowBox[{
       SuperscriptBox["Azint", "2"], "\[Rule]", "A0z"}]}], "}"}]}], "//", 
   "FullSimplify"}], "*)"}]], "Input",
 CellChangeTimes->{{3.7948463906879654`*^9, 3.7948464170537024`*^9}, 
   3.794846495652331*^9, 3.794846551273754*^9, {3.7948467405975623`*^9, 
   3.7948467450688047`*^9}},
 CellLabel->"In[48]:=",ExpressionUUID->"4c635b80-ee34-456e-b07c-18fca9261b4c"],

Cell[BoxData[
 RowBox[{"L0x", "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Mu]0", " ", 
      SuperscriptBox["\[Xi]", "2"], 
      RowBox[{"(", 
       RowBox[{"\[Chi]IPyy", "+", 
        RowBox[{
         SuperscriptBox["\[Zeta]", "2"], "\[Chi]IPzz"}]}], ")"}]}], 
     RowBox[{"4", " ", "w"}]], 
    SuperscriptBox["\[Eta]", "2"]}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Mu]0", " ", "Ms"}], 
     RowBox[{"4", " ", "w"}]], 
    SuperscriptBox["\[Xi]", "2"], "\[Chi]fitX", " ", 
    SuperscriptBox["\[Eta]", "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.782794070576606*^9, 3.7827940773528156`*^9}, {
   3.782794218917145*^9, 3.782794223197276*^9}, {3.7831508894973106`*^9, 
   3.783150916560482*^9}, {3.7948464273036637`*^9, 3.794846453379652*^9}, 
   3.7948467559273663`*^9, {3.795193226240612*^9, 
   3.7951932757571115`*^9}},ExpressionUUID->"ff73ecf7-283a-4805-8813-\
ad8fe901e4d4"],

Cell[BoxData[
 RowBox[{"L0y", "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Mu]0", " ", 
      SuperscriptBox["\[Xi]", "2"], " ", 
      SuperscriptBox["\[Zeta]", "2"], "\[Chi]IPzz"}], 
     RowBox[{"4", " ", "w"}]], 
    SuperscriptBox["\[Eta]", "2"]}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Mu]0", " ", "Ms", " "}], 
     RowBox[{"4", " ", "w"}]], 
    SuperscriptBox["\[Xi]", "2"], " ", 
    SuperscriptBox["\[Zeta]", "2"], "\[Chi]fitY", " ", 
    SuperscriptBox["\[Eta]", "2"]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.782794116144991*^9, 3.7827941206061482`*^9}, {
  3.782794230245489*^9, 3.7827942303304915`*^9}, {3.7831509197342496`*^9, 
  3.7831509301859627`*^9}, {3.794846516070495*^9, 3.794846534214441*^9}, {
  3.795193239802476*^9, 3.7951932423415346`*^9}, {3.7951932782555065`*^9, 
  3.795193279372279*^9}},ExpressionUUID->"8037f9a4-7831-4adf-8161-\
680ae8acc6f0"],

Cell[BoxData[
 RowBox[{"L0z", "=", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Mu]0", " ", 
      SuperscriptBox["\[Xi]", "2"], "\[Chi]OOPyy"}], 
     RowBox[{"4", " ", "w"}]], 
    SuperscriptBox["\[Eta]", "2"]}], "=", 
