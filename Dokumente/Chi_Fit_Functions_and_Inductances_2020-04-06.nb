Cell["\<\
We first consider H applied along z and obtain the dynamic magnetization\
\>", "Text",
 CellChangeTimes->{{3.781939690381793*^9, 3.781939699704762*^9}, {
  3.781957889337412*^9, 3.7819579021376915`*^9}, {3.783074316703125*^9, 
  3.7830743220795093`*^9}, {3.7830746480402436`*^9, 
  3.7830746536921873`*^9}},ExpressionUUID->"c609a3b7-fd26-450b-b79d-\
57017c114354"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"mZ", "=", 
   RowBox[{
    RowBox[{"{", " ", 
     RowBox[{
      RowBox[{
       FractionBox["1", "Ms"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Chi]", ".", "h1"}], ")"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ",", " ", 
      RowBox[{
       FractionBox["1", "Ms"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Chi]", ".", "h1"}], ")"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ",", "1"}], "}"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Chi]xz", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]yz", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zz", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zy", "\[Rule]", "0"}]}], "}"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dtmZ", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " "}], "Ms"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Chi]", ".", "h1"}], ")"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], ",", 
      RowBox[{
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " "}], "Ms"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Chi]", ".", "h1"}], ")"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ",", "0"}], "}"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Chi]xz", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]yz", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zz", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zy", "\[Rule]", "0"}]}], "}"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.781873405770239*^9, 3.7818734625682526`*^9}, {
   3.7830746581150603`*^9, 3.78307467292522*^9}, {3.783074883454348*^9, 
   3.7830749404927998`*^9}, 3.7830750221457195`*^9},
 CellLabel->"In[50]:=",ExpressionUUID->"195e2abc-1d54-4623-9852-b6c49c073a75"],

