Cell[CellGroupData[{

Cell["Testcase for fully shielded OOP driving fields", "Chapter",
 CellChangeTimes->{{3.7949012485403214`*^9, 
  3.794901267095068*^9}},ExpressionUUID->"d1b782ea-8653-4f75-9a04-\
a22f161a91c5"],

Cell["\<\
Finally, we check if Lx becomes linear if the OOP fields are shielded\
\>", "Text",
 CellChangeTimes->{{3.79485041593857*^9, 
  3.794850433610573*^9}},ExpressionUUID->"21af8246-ace9-4675-87b7-\
4f16de5517dc"],

Cell["Resonance frequency", "Text",
 CellChangeTimes->{{3.7948504350753317`*^9, 
  3.794850452108251*^9}},ExpressionUUID->"12019531-d99d-4b12-b9f9-\
1df19cf80a88"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"resonance", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Det", "[", "\[Chi]invip", "]"}], "\[Equal]", "0"}], ",", 
       "\[Omega]"}], "]"}], "[", 
     RowBox[{"[", "1", "]"}], "]"}], "/.", 
    RowBox[{
     SuperscriptBox["\[Alpha]", "2"], "\[Rule]", "0"}]}], "//", 
   "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.794850461107456*^9, 3.7948505415641594`*^9}, {
  3.7948505872768154`*^9, 3.7948505881746016`*^9}, {3.794850736600457*^9, 
  3.7948507595137157`*^9}, {3.79485081703296*^9, 3.7948508180342455`*^9}, {
  3.7948508516552114`*^9, 3.794850857201172*^9}},
 CellLabel->"In[68]:=",ExpressionUUID->"89beb220-a8e8-47f4-903a-f388fe577309"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\[Omega]", "\[Rule]", 
   RowBox[{
    RowBox[{"\[Gamma]", " ", 
     SqrtBox[
      RowBox[{"\[Mu]0H0", " ", 
       RowBox[{"(", 
        RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}]]}], "+", 
    RowBox[{
     FractionBox["1", "2"], " ", "\[ImaginaryI]", " ", "\[Alpha]", " ", 
     "\[Gamma]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "\[Mu]0H0"}], "+", "\[Mu]0Meff"}], ")"}]}]}]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.794850503331788*^9, 3.7948505103551087`*^9}, 
   3.794850543128131*^9, 3.794850588695197*^9, {3.7948507377524924`*^9, 
   3.794850760046693*^9}, 3.7948508184231987`*^9, 3.7948508577722893`*^9, 
   3.794901327463739*^9, 3.7951931689372587`*^9},
 CellLabel->"Out[68]=",ExpressionUUID->"83b41358-299c-4db8-aafd-3ef36c46b658"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[Omega]resIP", "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"ComplexExpand", "[", 
     RowBox[{"Re", "[", 
      RowBox[{"\[Omega]", "/.", "resonance"}], "]"}], "]"}], ",", " ", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"\[Mu]0H0", ">", "0"}], "&&", 
      RowBox[{"\[Mu]0Meff", ">", "0"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7948504543254766`*^9, 3.794850459459404*^9}, {
  3.794850601824661*^9, 3.794850675227225*^9}, {3.794850896534829*^9, 
  3.79485091293919*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"0814011f-4d9f-46d0-b328-0f6092a90851"],

Cell[BoxData[
 RowBox[{"\[Gamma]", " ", 
  SqrtBox[
   RowBox[{"\[Mu]0H0", " ", 
    RowBox[{"(", 
     RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}]]}]], "Output",
 CellChangeTimes->{{3.794850605685881*^9, 3.7948506479166117`*^9}, {
   3.794850898973814*^9, 3.7948509195174236`*^9}, 3.7949013274997396`*^9, 
   3.7951931689992585`*^9},
 CellLabel->"Out[69]=",ExpressionUUID->"c238ecbd-df57-48d8-9496-68d542d16820"]
}, Open  ]],

Cell["Resonance magnetic field", "Text",
 CellChangeTimes->{{3.794901662542494*^9, 
  3.7949016705559006`*^9}},ExpressionUUID->"9ab1dee8-59c5-433c-9a68-\
3564b0ba4f23"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"resH", "=", 
  RowBox[{"\[Mu]0H0", "/.", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{"\[Omega]resIP", "\[Equal]", "\[Omega]"}], ",", "\[Mu]0H0"}], 
     "]"}], "[", 
    RowBox[{"[", "2", "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.794901334332309*^9, 3.794901364955305*^9}, {
  3.7949014060303764`*^9, 3.7949014124395995`*^9}},
 CellLabel->"In[70]:=",ExpressionUUID->"47a5a4d4-65d6-46cd-af78-d62c635c9501"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "\[Mu]0Meff"}], "+", 
    SqrtBox[
     RowBox[{
      SuperscriptBox["\[Mu]0Meff", "2"], "+", 
      FractionBox[
       RowBox[{"4", " ", 
        SuperscriptBox["\[Omega]", "2"]}], 
       SuperscriptBox["\[Gamma]", "2"]]}]]}], ")"}]}]], "Output",
 CellChangeTimes->{{3.7949013505692654`*^9, 3.7949013657633657`*^9}, 
   3.794901413732584*^9, 3.7951931690572586`*^9},
 CellLabel->"Out[70]=",ExpressionUUID->"f4743b59-c8da-46fc-9d80-2226dda62ee6"]
}, Open  ]],

Cell["\<\
We insert the resonance magnetic field for each frequency and consider the \
normalized inductance L/\[Chi]:\
\>", "Text",
 CellChangeTimes->{{3.7949016749485703`*^9, 3.794901685520059*^9}, {
  3.79490176522511*^9, 
  3.7949017776225953`*^9}},ExpressionUUID->"3f7f4ef1-295b-4357-9e83-\
d31cb1d33323"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Lx0", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Lx", "/", "\[Chi]X"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Zeta]", "\[Rule]", "0"}], ",", 
      RowBox[{"\[Mu]0H0", "\[Rule]", "resH"}]}], "}"}]}], "//", 
   "Simplify"}]}]], "Input",
 CellChangeTimes->{{3.7949013824847317`*^9, 3.7949014414741163`*^9}, {
  3.7949014733069696`*^9, 3.794901475309981*^9}, {3.7949015292049217`*^9, 
  3.794901581651814*^9}, {3.794901639620346*^9, 3.7949016435411735`*^9}, {
  3.794901790243705*^9, 3.7949018157534266`*^9}},
 CellLabel->"In[71]:=",ExpressionUUID->"e2145448-ef43-4db2-9b00-fb3b059f2d35"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", "\[Eta]0", " ", "\[Xi]", " ", 
  RowBox[{"(", 
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Eta]0", " ", "\[Mu]0", " ", "\[Xi]"}], 
     "w"], "-", 
    FractionBox[
     RowBox[{"L12", " ", "\[Omega]", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[Mu]0Meff", " ", "\[Sigma]FL"}], "-", 
        RowBox[{"2", " ", "\[ImaginaryI]", " ", "\[Sigma]DL", " ", 
         SqrtBox[
          FractionBox[
           SuperscriptBox["\[Omega]", "2"], 
           SuperscriptBox["\[Gamma]", "2"]]]}], "+", 
        RowBox[{"\[Sigma]FL", " ", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["\[Mu]0Meff", "2"], "+", 
           FractionBox[
            RowBox[{"4", " ", 
             SuperscriptBox["\[Omega]", "2"]}], 
            SuperscriptBox["\[Gamma]", "2"]]}]]}]}], ")"}], " ", "\[HBar]"}], 
     RowBox[{"e", " ", "Ms", " ", 
      RowBox[{"(", 
       RowBox[{"\[Mu]0Meff", "+", 
        SqrtBox[
         RowBox[{
          SuperscriptBox["\[Mu]0Meff", "2"], "+", 
          FractionBox[
           RowBox[{"4", " ", 
            SuperscriptBox["\[Omega]", "2"]}], 
           SuperscriptBox["\[Gamma]", "2"]]}]]}], ")"}]}]]}], 
   ")"}]}]], "Output",
 CellChangeTimes->{{3.7949013848897247`*^9, 3.7949014421531878`*^9}, 
   3.7949014759952307`*^9, {3.7949015510536504`*^9, 3.7949015820548306`*^9}, 
   3.79490164423724*^9, {3.7949017909067297`*^9, 3.794901816355448*^9}, 
   3.795193169174261*^9},
 CellLabel->"Out[71]=",ExpressionUUID->"5481fc6c-c493-4c98-8500-40ad66bbd706"]
}, Open  ]],

Cell["Indeed, the real part is linear in \[Omega]", "Text",
 CellChangeTimes->{{3.7949016892959614`*^9, 
  3.7949016993442793`*^9}},ExpressionUUID->"ed33592b-062e-4539-af0e-\
33fdcd126be2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"Re", "[", "Lx0", "]"}], "]"}], ",", " ", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{
     RowBox[{"\[Mu]0H0", ">", "0"}], "&&", 
     RowBox[{"\[Mu]0Meff", ">", "0"}]}]}]}], "]"}]], "Input",
 CellChangeTimes->{3.794901487622561*^9},
