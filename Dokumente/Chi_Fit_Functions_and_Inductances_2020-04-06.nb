Cell["We can determine the factors Ayint and Azint numerically", "Text",
 CellChangeTimes->{{3.7825782682289515`*^9, 3.782578280784444*^9}, {
  3.782578910758539*^9, 
  3.7825789110627003`*^9}},ExpressionUUID->"3420c035-42c3-43fd-b211-\
3270ca3af172"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AyEval", "[", 
    RowBox[{"z_", ",", "w_"}], "]"}], ":=", 
   RowBox[{"Quiet", "[", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ArcTan", "[", 
          FractionBox[
           RowBox[{
            RowBox[{"w", "/", "2"}], "+", "y"}], "z"], "]"}], "+", 
         RowBox[{"ArcTan", "[", 
          FractionBox[
           RowBox[{
            RowBox[{"w", "/", "2"}], "-", "y"}], "z"], "]"}]}], ")"}], "2"], 
      ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", 
        RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], "]"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.782578282982534*^9, 3.7825782884435854`*^9}, {
  3.782578352158182*^9, 3.782578416263358*^9}, {3.782578453763153*^9, 
  3.7825784641614275`*^9}, {3.7825785171218233`*^9, 3.782578519933453*^9}, {
  3.7825787158879685`*^9, 3.7825787361361637`*^9}, {3.7948460071074157`*^9, 
  3.794846013292444*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"16e0ed37-1b71-41ec-acb4-bcc363b36199"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"AzEval", "[", 
    RowBox[{"z_", ",", "w_"}], "]"}], ":=", 
   RowBox[{"Quiet", "[", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"Log", "[", 
         FractionBox[
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"w", "/", "2"}], "+", "y"}], ")"}], "2"], "+", 
           SuperscriptBox["z", "2"]}], 
          RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"w", "/", "2"}], "-", "y"}], ")"}], "2"], "+", 
           SuperscriptBox["z", "2"]}]], "]"}], ")"}], "2"], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", 
        RowBox[{"-", "\[Infinity]"}], ",", "\[Infinity]"}], "}"}]}], "]"}], 
    "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7825786409995613`*^9, 3.7825786488791747`*^9}, 
   3.7825786810543127`*^9, {3.7825787392739286`*^9, 3.782578744201249*^9}, 
   3.7825787887540855`*^9, {3.7948460154369445`*^9, 3.79484602049763*^9}},
 CellLabel->"In[36]:=",ExpressionUUID->"9193e4a2-bb14-4c0a-83a6-51465e1211c3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
