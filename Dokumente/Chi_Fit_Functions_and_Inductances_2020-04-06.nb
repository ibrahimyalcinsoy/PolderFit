      RowBox[{"hy", "\[Rule]", 
       RowBox[{"\[Xi]", " ", 
        RowBox[{"I0", "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "w"}], ")"}]}], "\[Eta]0"}]}], ",", " ", 
      RowBox[{"hz", "\[Rule]", " ", "0"}]}], "}"}]}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.7830783098572936`*^9, 3.7830783843066387`*^9}, {
