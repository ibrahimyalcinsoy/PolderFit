 CellChangeTimes->{{3.794843656808736*^9, 3.794843666694934*^9}, {
  3.794843717892541*^9, 3.7948437736020007`*^9}, {3.7948438585413713`*^9, 
  3.794843890055651*^9}, {3.7948439814060187`*^9, 3.794844008638214*^9}, {
  3.794844620081627*^9, 3.7948446222442727`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"e2d9a268-a2fe-4990-ad9f-2407d50ff7f3"],

Cell[BoxData["\<\"(gamma**2*mu0*(gamma**2*mu0H0**2*(mu0H0 + mu0Meff) + ((-1 + \
alpha**2)*mu0H0 + alpha**2*mu0Meff)*omega**2))/(gamma**4*mu0H0**2*(mu0H0 + \
mu0Meff)**2 + gamma**2*(2*(-1 + alpha**2)*mu0H0**2 + 2*(-1 + \
alpha**2)*mu0H0*mu0Meff + alpha**2*mu0Meff**2)*omega**2 + (1 + \
alpha**2)**2*omega**4)\"\>"], "Output",
 CellChangeTimes->{{3.7948437279998274`*^9, 3.7948437741187143`*^9}, {
   3.794843860972645*^9, 3.7948438906176786`*^9}, 3.794843992581482*^9, 
   3.794844629431959*^9, 3.7948487253382177`*^9, 3.7949012898530836`*^9, 
   3.7951931300513005`*^9},
 CellLabel->"Out[14]=",ExpressionUUID->"d2d6f7a2-92a4-48f7-a1e4-d53b39d26d6f"]
}, Open  ]],

Cell["IP orthogonal imaginary :", "Text",
 CellChangeTimes->{{3.7948443702644405`*^9, 3.794844398065406*^9}, {
  3.7948446021763964`*^9, 
  3.794844604346064*^9}},ExpressionUUID->"d7301e49-2893-4dbb-9949-\
6b268ba5b9d4"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ToString", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Im", "[", "\[Chi]fitY", "]"}], "]"}], "/.", 
     "replacementrules"}], "//", "FullSimplify"}], "//", "FortranForm"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.794843656808736*^9, 3.794843666694934*^9}, {
   3.794843717892541*^9, 3.7948437736020007`*^9}, {3.7948438585413713`*^9, 
   3.794843890055651*^9}, {3.7948439814060187`*^9, 3.794844008638214*^9}, {
   3.794844384113356*^9, 3.794844384406371*^9}, 3.7948446250703573`*^9},
 CellLabel->"In[15]:=",ExpressionUUID->"bbde8967-8cd4-4ad5-9894-c3edd544e27b"],

Cell[BoxData["\<\"-((alpha*gamma*mu0*omega*(gamma**2*mu0H0**2 + (1 + \
alpha**2)*omega**2))/(gamma**4*mu0H0**2*(mu0H0 + mu0Meff)**2 + \
gamma**2*(2*(-1 + alpha**2)*mu0H0**2 + 2*(-1 + alpha**2)*mu0H0*mu0Meff + \
alpha**2*mu0Meff**2)*omega**2 + (1 + alpha**2)**2*omega**4))\"\>"], "Output",
 CellChangeTimes->{{3.7948437279998274`*^9, 3.7948437741187143`*^9}, {
   3.794843860972645*^9, 3.7948438906176786`*^9}, 3.794843992581482*^9, 
   3.7948443850012503`*^9, 3.794844631557123*^9, 3.79484872536722*^9, 
   3.7949012898940783`*^9, 3.7951931301333265`*^9},
 CellLabel->"Out[15]=",ExpressionUUID->"59389d6b-add4-4b13-b2ed-4b861c79da11"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell[" In-plane (H parallel to CPW, H || x):", "Section",
 CellChangeTimes->{{3.7948443295345974`*^9, 3.794844339661627*^9}, 
   3.7948445496592045`*^9, {3.794844658746519*^9, 3.7948446663086605`*^9}, {
   3.7948456095619164`*^9, 
   3.7948456154545755`*^9}},ExpressionUUID->"408af384-d42f-4ddb-8b0f-\
b9c7843388a8"],

Cell["IP parallel real:", "Text",
 CellChangeTimes->{{3.794844357524457*^9, 3.7948443755546017`*^9}, {
  3.7948446691580057`*^9, 
  3.794844673238126*^9}},ExpressionUUID->"e080f47b-452c-4a23-9bf8-\
90379f314746"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ToString", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Re", "[", "\[Chi]fitX", "]"}], "]"}], "/.", 
     "replacementrules"}], "//", "FullSimplify"}], "//", "FortranForm"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.794843656808736*^9, 3.794843666694934*^9}, {
   3.794843717892541*^9, 3.7948437736020007`*^9}, {3.7948438585413713`*^9, 
   3.794843890055651*^9}, {3.7948439814060187`*^9, 3.794844008638214*^9}, 
   3.7948446881521463`*^9},
 CellLabel->"In[16]:=",ExpressionUUID->"e80c92a2-28d9-4b91-9fea-62e21537dc02"],

Cell[BoxData["\<\"(gamma**2*mu0*(gamma**2*mu0H0*(mu0H0 + mu0Meff)*(mu0H0 + \
mu0Meff + mu0H0*ratio) + omega**2*((-1 + alpha**2)*mu0H0*(1 + ratio) + \
mu0Meff*(-1 + alpha**2*ratio))))/(gamma**4*mu0H0**2*(mu0H0 + mu0Meff)**2 + \
gamma**2*(2*(-1 + alpha**2)*mu0H0**2 + 2*(-1 + alpha**2)*mu0H0*mu0Meff + \
alpha**2*mu0Meff**2)*omega**2 + (1 + alpha**2)**2*omega**4)\"\>"], "Output",
 CellChangeTimes->{{3.7948437279998274`*^9, 3.7948437741187143`*^9}, {
   3.794843860972645*^9, 3.7948438906176786`*^9}, 3.794843992581482*^9, 
   3.7948446916918783`*^9, 3.7948487253962173`*^9, 3.7949012900530787`*^9, 
   3.795193130292298*^9},
 CellLabel->"Out[16]=",ExpressionUUID->"ee82352d-1beb-4d44-8a45-6e9fd6efd172"]
}, Open  ]],

Cell["IP parallel imaginary:", "Text",
 CellChangeTimes->{{3.7948443702644405`*^9, 3.794844398065406*^9}, {
  3.7948446766741543`*^9, 
  3.7948446815654955`*^9}},ExpressionUUID->"0804f11b-d1df-4e2e-a3ce-\
837833326740"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ToString", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"ComplexExpand", "[", 
      RowBox[{"Im", "[", "\[Chi]fitX", "]"}], "]"}], "/.", 
     "replacementrules"}], "//", "FullSimplify"}], "//", "FortranForm"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.794843656808736*^9, 3.794843666694934*^9}, {
   3.794843717892541*^9, 3.7948437736020007`*^9}, {3.7948438585413713`*^9, 
   3.794843890055651*^9}, {3.7948439814060187`*^9, 3.794844008638214*^9}, {
   3.794844384113356*^9, 3.794844384406371*^9}, 3.7948446897741537`*^9},
 CellLabel->"In[17]:=",ExpressionUUID->"49c3294a-ff2f-4adb-9ddd-5a0681e0d859"],

Cell[BoxData["\<\"-((alpha*gamma*mu0*omega*((1 + alpha**2)*omega**2*(1 + \
ratio) + gamma**2*((mu0H0 + mu0Meff)**2 + \
mu0H0**2*ratio)))/(gamma**4*mu0H0**2*(mu0H0 + mu0Meff)**2 + gamma**2*(2*(-1 + \
alpha**2)*mu0H0**2 + 2*(-1 + alpha**2)*mu0H0*mu0Meff + \
alpha**2*mu0Meff**2)*omega**2 + (1 + alpha**2)**2*omega**4))\"\>"], "Output",
 CellChangeTimes->{{3.7948437279998274`*^9, 3.7948437741187143`*^9}, {
   3.794843860972645*^9, 3.7948438906176786`*^9}, 3.794843992581482*^9, 
   3.7948443850012503`*^9, 3.794844694059479*^9, 3.7948487254742174`*^9, 
   3.7949012901930885`*^9, 3.7951931304493237`*^9},
 CellLabel->"Out[17]=",ExpressionUUID->"48df321d-15e5-48b1-910d-71d9f005184e"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["CPW sensitivity and dipolar inductance", "Chapter",
 CellChangeTimes->{{3.7948444498212705`*^9, 3.794844458708394*^9}, {
  3.7948461675789723`*^9, 3.7948461802350197`*^9}, {3.794846225914611*^9, 
  3.794846230068739*^9}},ExpressionUUID->"8094d0bb-9647-4b4f-980f-\
d90654e1801c"],

Cell["\<\
We now turn to the evaluation of L0 and LNM, where we use the coordinate \
system indicated in the figure above\
\>", "Text",
 CellChangeTimes->{{3.7831510057204123`*^9, 
  3.783151027173334*^9}},ExpressionUUID->"529f4f04-5e08-40ca-8b85-\
b4b900100379"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x0", "=", 
   RowBox[{"{", 
    RowBox[{"1", ",", "0", ",", "0"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y0", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"z0", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "0", ",", "1"}], "}"}]}], ";"}]}], "Input",
 CellLabel->"In[18]:=",ExpressionUUID->"28cf3e15-c8b0-4cd4-9aca-0cd3530cc1e4"],

Cell[CellGroupData[{

Cell["Driving fields", "Section",
 CellChangeTimes->{{3.7948469992110167`*^9, 
  3.7948470021270137`*^9}},ExpressionUUID->"edbe8857-eb97-4acf-b00f-\
00bc3ee34e34"],

Cell["\<\
The Karqvist model is used to describe the Oersted fields generated from the \
CPW\
\>", "Text",
 CellChangeTimes->{{3.7830741667824764`*^9, 
  3.7830741891894035`*^9}},ExpressionUUID->"f377814b-4d03-440b-b8d4-\
5a2373568ba5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hyKF", "=", 
   RowBox[{
    FractionBox["I0", 
     RowBox[{" ", 
      RowBox[{"2", " ", "w", " ", "\[Pi]"}]}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"ArcTan", "[", 
       FractionBox[
        RowBox[{
         RowBox[{"w", "/", "2"}], "+", "y"}], "z"], "]"}], "+", 
      RowBox[{"ArcTan", "[", 
       FractionBox[
        RowBox[{
         RowBox[{"w", "/", "2"}], "-", "y"}], "z"], "]"}]}], ")"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.7450817550213423`*^9, 3.7450817580183907`*^9}, 
   3.745082776980409*^9, 3.7450829624117546`*^9, 3.7450832914115267`*^9, {
   3.7451304696585674`*^9, 3.74513047268363*^9}, 3.7825656124422665`*^9, 
   3.782578309831444*^9},
 CellLabel->"In[21]:=",ExpressionUUID->"b181ae8e-9e68-49a0-a968-3e36fa456231"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hzKF", "=", 
   RowBox[{
    FractionBox["I0", 
     RowBox[{" ", 
      RowBox[{"4", " ", "w", " ", "\[Pi]"}]}]], 
    RowBox[{"Log", "[", 
     FractionBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"w", "/", "2"}], "+", "y"}], ")"}], "2"], "+", 
       SuperscriptBox["z", "2"]}], 
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{"w", "/", "2"}], "-", "y"}], ")"}], "2"], "+", 
       SuperscriptBox["z", "2"]}]], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7450829742619524`*^9, 3.7450829755455427`*^9}, {
   3.7451304780187426`*^9, 3.745130480784801*^9}, 3.7825656078418064`*^9, 
   3.782578314445878*^9},
 CellLabel->"In[22]:=",ExpressionUUID->"0e12efe2-fecf-41da-b0d3-fbffba532d0a"],

Cell["\<\
Same equations can be simplified by introducing parameters Ay and Az\
\>", "Text",
 CellChangeTimes->{{3.7830741930089083`*^9, 
  3.7830742102984486`*^9}},ExpressionUUID->"ffd8a208-dada-4d2d-aa6f-\
f1c4d85a29d4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hyK", "=", 
   RowBox[{
    FractionBox["I0", 
     RowBox[{" ", 
      RowBox[{"2", " ", "w", " ", "\[Pi]"}]}]], "Ay"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.782577345615222*^9, 3.782577364082301*^9}},
 CellLabel->"In[23]:=",ExpressionUUID->"d4de6c59-7f83-4bcd-a94b-ff78a2dc0b03"],

Cell[BoxData[
 RowBox[{
  RowBox[{"hzK", "=", 
   RowBox[{
    FractionBox["I0", 
     RowBox[{" ", 
      RowBox[{"4", " ", "w", " ", "\[Pi]"}]}]], "Az"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7825773702167144`*^9, 3.7825773840968046`*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"a45e8af4-bcb9-4161-9ba2-5a1dc1175575"],

Cell["Where", "Text",
 CellChangeTimes->{{3.783147678454222*^9, 3.783147681159774*^9}, 
   3.7831477111691837`*^9},ExpressionUUID->"3b2ae6ed-d8ca-4e87-9863-\
97fc3f4cbf91"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Ay", "=", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"ArcTan", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"w", "/", "2"}], "+", "y"}], "z"], "]"}], "+", 
     RowBox[{"ArcTan", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"w", "/", "2"}], "-", "y"}], "z"], "]"}]}], ")"}]}], 
  " "}], "\[LineSeparator]", 
 RowBox[{"Az", "=", 
  RowBox[{"Log", "[", 
   FractionBox[
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"w", "/", "2"}], "+", "y"}], ")"}], "2"], "+", 
     SuperscriptBox["z", "2"]}], 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"w", "/", "2"}], "-", "y"}], ")"}], "2"], "+", 
     SuperscriptBox["z", "2"]}]], "]"}]}]}], "DisplayFormula",
 CellChangeTimes->{{3.783147684731419*^9, 3.783147724539576*^9}, {
  3.7831477628725586`*^9, 
  3.7831477707320604`*^9}},ExpressionUUID->"95f1e0db-17a2-4447-98a7-\
9d4f73147628"],

Cell["The driving field vector is given by", "Text",
 CellChangeTimes->{{3.783074216304796*^9, 
  3.7830742234040775`*^9}},ExpressionUUID->"57da3d63-1cf6-43eb-a882-\
39b94121074c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"h1", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", "hy", ",", "hz"}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7825651232643538`*^9, 3.7825651375717845`*^9}},
 CellLabel->"In[25]:=",ExpressionUUID->"9d46692b-1011-4752-a6b7-68dc46ea7614"],

Cell["And the unitless magnetic susceptibility in general is", "Text",
 CellChangeTimes->{{3.783074226240551*^9, 3.783074234040552*^9}, {
  3.7951939375931997`*^9, 
  3.795193938724265*^9}},ExpressionUUID->"2ea75c49-fc5b-4ba0-80d1-\
ff31b2d033ee"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Chi]", "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {"\[Chi]xx", "\[Chi]xy", "\[Chi]xz"},
      {"\[Chi]yx", "\[Chi]yy", "\[Chi]yz"},
      {"\[Chi]zx", "\[Chi]zy", "\[Chi]zz"}
     }], "\[NoBreak]", ")"}]}], ";"}]], "Input",
 CellLabel->"In[26]:=",ExpressionUUID->"dd3f0c7c-42fe-40f6-9f10-3fb29351f9ce"],

Cell["Resulting in the magnetization (linear response)", "Text",
 CellChangeTimes->{{3.783074239794036*^9, 
  3.78307424854594*^9}},ExpressionUUID->"b15698d8-bc2d-4502-9782-\
a9ec1108069f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"m", "=", 
   RowBox[{"\[Chi]", ".", "h1"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.782566156451662*^9, 3.7825661638644032`*^9}},
 CellLabel->"In[27]:=",ExpressionUUID->"971d5c88-a8e5-4d38-8694-eb1e2c0deee3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["CPW sensitivity by reciprocity", "Section",
 CellChangeTimes->{{3.7948469992110167`*^9, 
  3.794847028533073*^9}},ExpressionUUID->"ea358984-1dae-4d66-886c-\
2ff4824e9fe1"],

Cell["\<\
We rely on principle of reciprocity. If the magnetic field of the CPW due to \
current I0 is given by H(y,z) = CH(y,z)*I0 with any function CH, then the \
inductance generated by a magnetic dipole moment is L=\[Phi]/I0 with flux \
\[Phi]=\[Mu]0 CH(y,z) m(y,z)\
\>", "Text",
 CellChangeTimes->{{3.7825766079078956`*^9, 
  3.7825767721119385`*^9}},ExpressionUUID->"d38a4c1d-4e48-40f3-b80b-\
646d344bce24"],

Cell[TextData[{
 "The general form of the inductance of sample with volume V is thus L0=",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[Mu]0", " "}], "I0"], TraditionalForm]],ExpressionUUID->
  "ed2593fd-736c-454e-acd0-7a6d2b4134c7"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Integral]", 
    RowBox[{"CH", " ", "*", "m", 
     RowBox[{"\[DifferentialD]", "V"}]}]}], TraditionalForm]],ExpressionUUID->
  "ec73681a-3eea-40e8-953a-7f9878194297"],
 "=",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[Mu]0", " "}], "I0"], TraditionalForm]],ExpressionUUID->
  "109380e3-4304-4b9f-8d68-ee97488e5b1d"],
 "d l",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Integral]", 
     RowBox[{"-", "\[Infinity]"}], "\[Infinity]"], 
    RowBox[{"CH", "*", "m", 
     RowBox[{"\[DifferentialD]", "y"}]}]}], TraditionalForm]],ExpressionUUID->
  "a342b6e5-021a-4823-9b6e-7501fba4372c"],
 ", where we assume that the film has small thickness d and length l, so we \
only have to integrate over y."
}], "Text",
 CellChangeTimes->{{3.7825779213920717`*^9, 
  3.782578110274007*^9}},ExpressionUUID->"c0c39242-9419-4b0b-8a22-\
aad5a4a87215"],

Cell["We define the sensitivity function", "Text",
 CellChangeTimes->{{3.782565779667988*^9, 3.782565783260347*^9}, {
  3.783147651890853*^9, 
  3.783147655331275*^9}},ExpressionUUID->"3df70d4b-5bfa-4ab7-a0a7-\
d964fbdcbccb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"CH", "=", 
   RowBox[{"{", 
    RowBox[{"0", ",", " ", 
     RowBox[{"hy", "/", "I0"}], ",", " ", 
     RowBox[{"hz", "/", "I0"}]}], "}"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.78256578499552*^9, 3.7825658148015003`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"00081538-3511-40d1-9682-abff78c5bd3b"],

Cell["\<\
We now need to write down all terms in the form CH*m. For the Hx case all \
components of \[Chi] that contain an index x vanish. Furthermore, \
off-diagonal elements of \[Chi] have identical magnitude but opposite sign. \
We consider shielding (or amplification due to image currents) of the driving \
fields hy and hz by a factor \[Xi] and also consider that the driving field \
hy might be shielded differently to the driving field hz by the factor \
\[Zeta] already introduced above.\
\>", "Text",
 CellChangeTimes->{{3.7825761143425617`*^9, 3.782576119929779*^9}, {
   3.782578120384202*^9, 3.7825781309862537`*^9}, {3.7831478639265747`*^9, 
   3.7831479243882966`*^9}, 3.794845521469997*^9, {3.794845630778709*^9, 
   3.794845662056382*^9}, {3.7948457840842085`*^9, 
   3.794845856681556*^9}},ExpressionUUID->"b0846594-ec35-4c27-a267-\
d8dcd948c32d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"mSensx", "=", 
  RowBox[{"Collect", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"m", ".", "CH"}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Chi]xx", "\[Rule]", "0"}], ",", " ", 
       RowBox[{"\[Chi]xy", "\[Rule]", "0"}], ",", " ", 
       RowBox[{"\[Chi]xz", "\[Rule]", "0"}], ",", 
       RowBox[{"\[Chi]yx", "\[Rule]", "0"}], ",", " ", 
       RowBox[{"\[Chi]zx", "\[Rule]", "0"}], ",", " ", 
       RowBox[{"\[Chi]zy", "\[Rule]", 
        RowBox[{"-", "\[Chi]yz"}]}], ",", 
       RowBox[{"hy", "\[Rule]", 
        RowBox[{"\[Xi]", "  ", "hyK"}]}], ",", " ", 
       RowBox[{"hz", "\[Rule]", 
        RowBox[{"\[Xi]", " ", "\[Zeta]", " ", "hzK"}]}]}], "}"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Chi]yy", ",", " ", "\[Chi]zz"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7825761391933007`*^9, 3.782576198965311*^9}, {
   3.7825763839863973`*^9, 3.782576417116624*^9}, {3.7825765006616735`*^9, 
   3.7825765021437035`*^9}, 3.782577163870572*^9, {3.7825771971484995`*^9, 
