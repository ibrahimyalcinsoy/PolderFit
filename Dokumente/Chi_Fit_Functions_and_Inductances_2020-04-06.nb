Cell[CellGroupData[{

Cell["Inductances", "Section",
 CellChangeTimes->{{3.7948469992110167`*^9, 3.7948470021270137`*^9}, {
  3.7948470755523233`*^9, 
  3.7948470766764174`*^9}},ExpressionUUID->"e5888db1-c953-4005-8127-\
dce537a297b5"],

Cell[TextData[{
 "For all these, integration needs to be done only over the terms ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Ay", "2"], TraditionalForm]],ExpressionUUID->
  "2e5d0efd-1c43-407a-91c0-e4015499c598"],
 " and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["Az", "2"], TraditionalForm]],ExpressionUUID->
  "6c69a797-4f9e-4d5c-af69-a8bcbf8caa41"],
 ", as other terms do not depend on y. Furthermore, we assume uniform driving \
field along length and thickness of the ferromagnet, so that integration of \
length and thickness can be replaced by multiplication. We thus obtain the \
inductances  L0=",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[Mu]0", " "}], "I0"], TraditionalForm]],ExpressionUUID->
  "62e848b0-4dbb-4a5c-b693-67da98d77a6d"],
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Integral]", 
    RowBox[{"CH", " ", "*", "m", 
     RowBox[{"\[DifferentialD]", "V"}]}]}], TraditionalForm]],ExpressionUUID->
  "52cad732-df8e-45ef-a46e-58f539d9e8d0"],
 "=",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{"\[Mu]0", " "}], "I0"], TraditionalForm]],ExpressionUUID->
  "7fd00daa-d22b-4b9e-ba2d-00b7b5ef5587"],
 "d l",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Integral]", 
     RowBox[{"-", "\[Infinity]"}], "\[Infinity]"], 
    RowBox[{"CH", "*", "m", 
     RowBox[{"\[DifferentialD]", "y"}]}]}], TraditionalForm]],ExpressionUUID->
  "92087d78-04b6-44bb-bb1b-c2c2914e4ce6"],
 ":"
}], "Text",
 CellChangeTimes->{{3.782578189668471*^9, 3.7825782478765907`*^9}, {
  3.783147975366042*^9, 
  3.783148048309802*^9}},ExpressionUUID->"5617d035-e360-4faa-97bb-\
0d5239e054a2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"L0x", "=", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"\[Mu]0", " ", "l", " ", "d"}], "I0"], " ", "mSensx"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Ay", "\[Rule]", "Ayint"}], ",", " ", 
      RowBox[{"Az", "\[Rule]", "Azint"}]}], "}"}]}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.7825658196479855`*^9, 3.782565846266647*^9}, {
   3.782566069259944*^9, 3.7825661403040476`*^9}, {3.782566235517568*^9, 
