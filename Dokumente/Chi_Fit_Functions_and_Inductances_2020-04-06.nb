  3.783075746176319*^9, 
  3.7830757523193455`*^9}},ExpressionUUID->"9d73cab3-8910-49ec-9c1c-\
52be1ad0d304"],

Cell[BoxData[
 RowBox[{"LNMz", "=", 
  RowBox[{
   RowBox[{"L12", " ", 
    FractionBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\[Sigma]DL", "+", 
