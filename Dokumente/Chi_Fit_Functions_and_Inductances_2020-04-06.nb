Cell[CellGroupData[{

Cell["H || y", "Section",
 CellChangeTimes->{{3.794849391514888*^9, 3.794849398604686*^9}, {
  3.794849467186279*^9, 3.794849468557255*^9}, {3.794849949325509*^9, 
  3.794849951777156*^9}},ExpressionUUID->"9963e128-39fd-46cc-9fd3-\
da476040d5fa"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Ly", "=", " ", 
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Mu]0", " "}], 
     RowBox[{"4", " ", "w"}]], 
    SuperscriptBox["\[Xi]", "2"], " ", 
    SuperscriptBox["\[Zeta]", "2"], "\[Chi]Y", " ", 
    SuperscriptBox["\[Eta]0", "2"]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.7948491078985996`*^9, 3.7948492383905315`*^9}, 
   3.7948493507756743`*^9, 3.794849469755271*^9, 3.7948495343800564`*^9, {
   3.794849869124906*^9, 3.7948498732306333`*^9}},
 CellLabel->"In[67]:=",ExpressionUUID->"59fa7331-2d00-4c98-8cfe-4cfb903de9fc"]
}, Open  ]]
