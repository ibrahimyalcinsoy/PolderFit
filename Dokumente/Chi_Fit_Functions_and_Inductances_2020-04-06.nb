}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["H || x", "Section",
 CellChangeTimes->{{3.794849391514888*^9, 3.794849398604686*^9}, 
   3.794849455024807*^9, {3.794849938120364*^9, 
   3.794849939680815*^9}},ExpressionUUID->"0d93526e-969d-4009-bfa7-\
95f6d77c4b54"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Lx", "=", 
   RowBox[{
    RowBox[{
     FractionBox[
      RowBox[{"d", " ", "l", " ", "\[Mu]0", " "}], 
      RowBox[{"4", " ", "w"}]], 
     SuperscriptBox["\[Xi]", "2"], "\[Chi]X", " ", 
     SuperscriptBox["\[Eta]0", "2"]}], "+", 
    RowBox[{"\[ImaginaryI]", " ", "L12", " ", 
     FractionBox[
      RowBox[{" ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SqrtBox[
            RowBox[{"\[Mu]0H0", " ", 
             RowBox[{"(", 
              RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}]], " ", 
           "\[Sigma]DL"}], "+", 
          RowBox[{"\[ImaginaryI]", " ", 
           RowBox[{"(", 
            RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}], " ", 
           "\[Sigma]FL"}]}], ")"}], " ", "\[HBar]", " ", "\[Omega]", " "}]}], 
      RowBox[{"4", " ", "e", " ", "Ms", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", "\[Zeta]"}], ")"}], "\[Mu]0H0"}], "+", 
         "\[Mu]0Meff"}], ")"}]}]], "\[Xi]", " ", "\[Eta]0", " ", 
     "\[Chi]X"}]}]}], " ", ";"}]], "Input",
 CellChangeTimes->{{3.7948491078985996`*^9, 3.7948492383905315`*^9}, 
   3.7948493507756743`*^9, 3.794849457897808*^9, {3.7948495114100475`*^9, 
   3.794849572224388*^9}},
 CellLabel->"In[64]:=",ExpressionUUID->"0ddadaa7-a68e-420b-96c9-35550f3f6e0b"],

Cell["With real part", "Text",
 CellChangeTimes->{{3.794849401053666*^9, 
  3.7948494035608196`*^9}},ExpressionUUID->"e47d82b9-48f2-458f-889b-\
9a415656b1ea"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ReLx", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"ComplexExpand", "[", 
     RowBox[{"Re", "[", "Lx", "]"}], "]"}], ",", " ", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"\[Mu]0H0", ">", "0"}], "&&", 
      RowBox[{"\[Mu]0Meff", ">", "0"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7948493549029417`*^9, 3.794849369096525*^9}, {
  3.7948494590504227`*^9, 3.7948494626168394`*^9}, {3.794849583676194*^9, 
  3.7948495854178553`*^9}, {3.7948496501398087`*^9, 3.7948496842008214`*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"e83c3d08-ced0-41e2-84cd-69dff5e555db"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "4"], " ", "\[Eta]0", " ", "\[Xi]", " ", "\[Chi]X", " ", 
  RowBox[{"(", 
   RowBox[{
    FractionBox[
     RowBox[{"d", " ", "l", " ", "\[Eta]0", " ", "\[Mu]0", " ", "\[Xi]"}], 
     "w"], "-", 
    FractionBox[
     RowBox[{"L12", " ", 
      RowBox[{"(", 
       RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}], " ", "\[Sigma]FL", " ",
       "\[Omega]", " ", "\[HBar]"}], 
     RowBox[{"e", " ", "Ms", " ", 
      RowBox[{"(", 
       RowBox[{"\[Mu]0H0", "+", 
        RowBox[{"\[Zeta]", " ", "\[Mu]0H0"}], "+", "\[Mu]0Meff"}], ")"}]}]]}],
    ")"}]}]], "Output",
 CellChangeTimes->{
  3.794849369633524*^9, 3.7948495761283894`*^9, {3.79484964728981*^9, 
   3.7948496851028233`*^9}, 3.7949013272727394`*^9, 3.795193168754363*^9},
 CellLabel->"Out[65]=",ExpressionUUID->"a33c3f89-ce59-4d32-8e28-1b0b84a94897"]
}, Open  ]],

Cell["And imaginary part", "Text",
 CellChangeTimes->{{3.7948494069428186`*^9, 3.7948494091383915`*^9}, 
   3.794849446325509*^9},ExpressionUUID->"efb6dc5c-26df-474f-9721-\
c96eacb8bf7b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ImLx", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"ComplexExpand", "[", 
     RowBox[{"Im", "[", "Lx", "]"}], "]"}], ",", " ", 
    RowBox[{"Assumptions", "\[Rule]", 
     RowBox[{
      RowBox[{"\[Mu]0H0", ">", "0"}], "&&", 
      RowBox[{"\[Mu]0Meff", ">", "0"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7948494145035753`*^9, 3.794849418330536*^9}, {
  3.794849460308584*^9, 3.794849464146843*^9}, {3.7948498188930397`*^9, 
  3.7948498218723197`*^9}},
 CellLabel->"In[66]:=",ExpressionUUID->"d126d6c1-6452-4857-8220-1597107ceb25"],

Cell[BoxData[
 FractionBox[
  RowBox[{"L12", " ", "\[Eta]0", " ", 
   SqrtBox[
    RowBox[{"\[Mu]0H0", " ", 
     RowBox[{"(", 
      RowBox[{"\[Mu]0H0", "+", "\[Mu]0Meff"}], ")"}]}]], " ", "\[Xi]", " ", 
   "\[Sigma]DL", " ", "\[Chi]X", " ", "\[Omega]", " ", "\[HBar]"}], 
  RowBox[{
   RowBox[{"4", " ", "e", " ", "Ms", " ", "\[Mu]0H0"}], "+", 
   RowBox[{"4", " ", "e", " ", "Ms", " ", "\[Zeta]", " ", "\[Mu]0H0"}], "+", 
   RowBox[{"4", " ", "e", " ", "Ms", " ", "\[Mu]0Meff"}]}]]], "Output",
 CellChangeTimes->{3.7948494188715363`*^9, 3.7948498239274263`*^9, 
  3.7949013274047375`*^9, 3.795193168850442*^9},
