    RowBox[{"{", 
     RowBox[{"\[Epsilon]", "\[Rule]", "\[Epsilon]0"}], "}"}]}], ",", " ", 
   RowBox[{"Assumptions", "\[Rule]", 
    RowBox[{"\[Mu]0H0", ">", "0"}]}]}], " ", "]"}]], "Input",
 CellChangeTimes->{{3.7830779083109727`*^9, 3.7830779365083046`*^9}, {
  3.783078039418225*^9, 3.783078057269191*^9}, {3.783078106562832*^9, 
