Cell[BoxData[
 RowBox[{"LNMx", "=", 
  RowBox[{
   RowBox[{"L12", " ", 
    FractionBox[
     RowBox[{" ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SqrtBox[
