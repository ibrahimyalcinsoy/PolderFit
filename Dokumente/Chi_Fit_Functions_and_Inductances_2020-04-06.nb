 CellLabel->"Out[57]=",ExpressionUUID->"1351aaa8-451b-42d0-8aff-8e905aade231"]
}, Open  ]],

Cell["\<\
We fit the X - data with \[Chi]IPyy+ \[Zeta] \[Chi]IPzz=((\[ImaginaryI] \
\[Epsilon] \[Chi]zy)+\[Zeta](\[ImaginaryI] /\[Epsilon]  \[Chi]zy) ), so we \
have to consider the ellipticity\
\>", "Text",
 CellChangeTimes->{{3.7830777664063473`*^9, 3.78307780928496*^9}, {
  3.783077861359539*^9, 3.7830779043412204`*^9}, {3.7830780287581167`*^9, 
