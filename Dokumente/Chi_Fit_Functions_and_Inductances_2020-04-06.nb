Cell[CellGroupData[{

Cell["Spacing loss", "Section",
 CellChangeTimes->{{3.7948469992110167`*^9, 3.7948470021270137`*^9}, {
  3.7948471054413233`*^9, 
  3.794847107495573*^9}},ExpressionUUID->"a3387785-bf9e-4647-a8ef-\
1090af1370c7"],

Cell["\<\
For the spacing loss (as shown above, identical for Hy and Hz) we take the \
usual approximation\
\>", "Text",
 CellChangeTimes->{{3.782579876012621*^9, 
  3.7825799036388617`*^9}},ExpressionUUID->"7ba85b5a-b7b8-45e1-86a6-\
b166814ccd47"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Eta]", "=", 
   RowBox[{
    FractionBox["2", "\[Pi]"], 
    RowBox[{"ArcTan", "[", 
     FractionBox["w", 
      RowBox[{"2", "z"}]], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.782579905455538*^9, 3.7825799415998487`*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"0ed77d26-24dc-4cae-b785-11d8f4764afd"],

Cell["\<\
We now can plot the simplified spacing loss \[Eta] together with the exact \
spacing loss as a function of z/w :\
\>", "Text",
 CellChangeTimes->{{3.7825802677537413`*^9, 3.782580305485731*^9}, {
  3.7827944065450897`*^9, 3.7827944443842683`*^9}, {3.7831482679537745`*^9, 
  3.7831482685739803`*^9}},ExpressionUUID->"235f5ce0-72d6-417f-a0be-\
bb405dcb2553"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", " ", 
    RowBox[{
     RowBox[{
      SuperscriptBox["\[Eta]", "2"], "/.", 
      RowBox[{"{", 
       RowBox[{"w", "\[Rule]", "1"}], "}"}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"AyEval", "[", 
        RowBox[{"z", ",", "1"}], "]"}], "/", "A0y"}], "/.", 
      RowBox[{"{", 
       RowBox[{"w", "\[Rule]", "1"}], "}"}]}], ",", " ", 
     RowBox[{"\[Eta]", "/.", 
      RowBox[{"{", 
       RowBox[{"w", "\[Rule]", "1"}], "}"}]}], ",", 
     RowBox[{
      SqrtBox[
       RowBox[{
        RowBox[{"AyEval", "[", 
         RowBox[{"z", ",", "1"}], "]"}], "/", "A0y"}]], "/.", 
      RowBox[{"{", 
       RowBox[{"w", "\[Rule]", "1"}], "}"}]}]}], " ", " ", "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"z", ",", "0", ",", "1"}], "}"}], ",", " ", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", " ", 
   RowBox[{"PlotLegends", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<Simple \!\(\*SuperscriptBox[\(\[Eta]\), \(2\)]\)\>\"", ",", " ", 
      "\"\<exact \!\(\*SuperscriptBox[\(\[Eta]\), \(2\)]\)\>\"", ",", " ", 
      "\"\<Simple \[Eta]\>\"", ",", " ", "\"\<exact \[Eta]\>\""}], "}"}]}], 
   ",", " ", 
   RowBox[{"Frame", "\[Rule]", "True"}], ",", " ", 
   RowBox[{"Axes", "\[Rule]", "False"}], ",", " ", 
   RowBox[{"FrameLabel", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<z/w\>\"", ",", "\"\<Spacing Loss\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.782579998261423*^9, 3.782580076262932*^9}, {
  3.7825801146619444`*^9, 3.7825802553407946`*^9}, {3.7825803144533587`*^9, 
