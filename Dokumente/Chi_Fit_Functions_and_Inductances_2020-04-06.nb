        RowBox[{"[", "2", "]"}], "]"}]}], ",", " ", 
      RowBox[{
       FractionBox["1", "Ms"], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Chi]", ".", "h1"}], ")"}], "[", 
        RowBox[{"[", "3", "]"}], "]"}]}]}], "}"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Chi]xx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]yx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]zx", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]xy", "\[Rule]", "0"}], ",", " ", 
      RowBox[{"\[Chi]xz", "\[Rule]", "0"}]}], "}"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dtmX", "=", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0", ",", 
      RowBox[{
       FractionBox[
        RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " "}], "Ms"], 
