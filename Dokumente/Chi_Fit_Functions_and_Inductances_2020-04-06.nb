      "\[HBar]", " ", "\[Omega]", " "}], 
     RowBox[{"2", " ", "e"}]], " ", "\[Xi]", " ", "\[Eta]", " ", 
    "\[Chi]fitZ"}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.7827941511710787`*^9, 3.7827941573742695`*^9}, {
