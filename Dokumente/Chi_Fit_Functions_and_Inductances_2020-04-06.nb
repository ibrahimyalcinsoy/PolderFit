26cbfce6a29a"],

Cell["The total inductances add as L0 + \[ImaginaryI] LNM", "Text",
 CellChangeTimes->{{3.794848963392621*^9, 3.7948489841188*^9}, {
   3.7948490751256*^9, 3.794849077613598*^9}, 
